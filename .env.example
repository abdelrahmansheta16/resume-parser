# API Configuration
API_PORT=8000
STREAMLIT_PORT=8501

# Model Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_sm

# Upload Limits
MAX_UPLOAD_SIZE_MB=10

# Feature Flags
OCR_ENABLED=true
FEEDBACK_ENABLED=true

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=*
