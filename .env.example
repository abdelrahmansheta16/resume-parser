# API Configuration
API_PORT=8000
STREAMLIT_PORT=8501

# Model Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_sm

# Upload Limits
MAX_UPLOAD_SIZE_MB=10

# Feature Flags
OCR_ENABLED=true
FEEDBACK_ENABLED=true

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=*

# Job Discovery API Keys
JOOBLE_API_KEY=
ADZUNA_APP_ID=
ADZUNA_API_KEY=
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# Job Discovery Settings
JOB_DISCOVERY_MAX_RESULTS=500
MAX_TOP_JOBS=50

# LLM Enhancement (optional — enables Claude-powered tailoring)
ANTHROPIC_API_KEY=
LLM_TAILORING_ENABLED=false

# LinkedIn Search
LINKEDIN_SEARCH_ENABLED=true

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_STORAGE_BUCKET=documents

# Rate Limiting
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_PARSE=20/minute
RATE_LIMIT_DISCOVER=10/minute

# Scheduler
SCHEDULER_ENABLED=false
